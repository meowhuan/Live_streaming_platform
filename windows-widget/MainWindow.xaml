<Window x:Class="MeowLiveChatWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MeowLiveChatWidget"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="喵喵直播间 - 弹幕小组件"
        Height="680" Width="420"
        MinHeight="480" MinWidth="320"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#121218"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="6" CaptionHeight="0" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Window.Resources>
        <LinearGradientBrush x:Key="MeowShellBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1A1826" Offset="0" />
            <GradientStop Color="#201C2E" Offset="0.55" />
            <GradientStop Color="#15131E" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="MeowPanelBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#241F35" Offset="0" />
            <GradientStop Color="#1C1A27" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="MeowBorderBrush" Color="#33FFFFFF" />
        <SolidColorBrush x:Key="MeowSoftText" Color="#B8AED4" />
        <SolidColorBrush x:Key="MeowAccent" Color="#CBB6FF" />
        <SolidColorBrush x:Key="MeowCardBorder" Color="#2C2A3A" />
        <SolidColorBrush x:Key="MeowCardFill" Color="#242432" />

        <Style x:Key="MeowMiniButton" TargetType="Button">
            <Setter Property="Background" Value="#2A273C" />
            <Setter Property="Foreground" Value="#F3F0FF" />
            <Setter Property="BorderBrush" Value="#3A3553" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="MeowMiniToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#2A273C" />
            <Setter Property="Foreground" Value="#F3F0FF" />
            <Setter Property="BorderBrush" Value="#3A3553" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Border x:Name="Root" CornerRadius="0" BorderThickness="0" Padding="0" ClipToBounds="True"
            BorderBrush="Transparent" Background="{StaticResource MeowShellBrush}">
        <Grid Margin="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="2,2,2,12" MouseLeftButtonDown="OnHeaderMouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="弹幕监视" FontSize="18" FontWeight="Bold" Foreground="#F6F3FF" />
                    <TextBlock Text="直播中互动实时显示" FontSize="12" Foreground="{StaticResource MeowSoftText}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <ToggleButton x:Name="TopmostToggle" Content="置顶" Width="54" Height="26" Margin="0,0,6,0" Style="{StaticResource MeowMiniToggle}" Click="OnTopmostToggle" />
                    <Button Content="×" Width="28" Height="26" Style="{StaticResource MeowMiniButton}" Click="OnCloseClick" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" CornerRadius="18" BorderThickness="1" BorderBrush="{StaticResource MeowBorderBrush}"
                    Background="{StaticResource MeowPanelBrush}" Padding="10">
                <Border.Resources>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    </Style>
                    <Style TargetType="ScrollBar">
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Setter Property="IsTabStop" Value="False" />
                    </Style>
                    <Style TargetType="Thumb">
                        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                        <Setter Property="IsTabStop" Value="False" />
                    </Style>
                </Border.Resources>
                <ScrollViewer x:Name="ChatScroll" VerticalScrollBarVisibility="Auto" ScrollChanged="OnChatScroll" BorderThickness="0" Background="Transparent">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar">
                            <Setter Property="Width" Value="8" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Grid Background="Transparent" Width="{TemplateBinding Width}" Opacity="0.65">
                                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                <Track.DecreaseRepeatButton>
                                                    <RepeatButton Command="ScrollBar.LineUpCommand" Opacity="0" />
                                                </Track.DecreaseRepeatButton>
                                                <Track.Thumb>
                                                    <Thumb>
                                                        <Thumb.Template>
                                                            <ControlTemplate TargetType="Thumb">
                                                                <Border Background="#66FFFFFF" CornerRadius="4" Margin="0,2,2,2" />
                                                            </ControlTemplate>
                                                        </Thumb.Template>
                                                    </Thumb>
                                                </Track.Thumb>
                                                <Track.IncreaseRepeatButton>
                                                    <RepeatButton Command="ScrollBar.LineDownCommand" Opacity="0" />
                                                </Track.IncreaseRepeatButton>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ScrollViewer.Resources>
                    <ItemsControl x:Name="ChatList" ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Background="{StaticResource MeowCardFill}" BorderBrush="{StaticResource MeowCardBorder}" BorderThickness="1" Padding="10" Margin="0,0,0,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding User}" FontWeight="SemiBold" Foreground="{StaticResource MeowAccent}" Margin="0,0,6,0" />
                                        <TextBlock Text="{Binding Text}" Foreground="#F0EFF6" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="2" Margin="2,12,2,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border CornerRadius="999" Background="#2B2740" BorderBrush="#3A3553" BorderThickness="1" Padding="10,4" Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Text="连接中" Foreground="#9ED9C7" FontSize="12" />
                </Border>
                <TextBlock x:Name="NoticeText" Grid.Column="1" Text="" Foreground="#F5C48B" FontSize="12" VerticalAlignment="Center" Margin="8,0" />
                <Button x:Name="ScrollBottomButton" Grid.Column="2" Content="新弹幕" Visibility="Collapsed" Style="{StaticResource MeowMiniButton}" Click="OnScrollBottom" />
            </Grid>
        </Grid>
    </Border>
</Window>
